# Copy this to .env and fill in your values
# Never commit .env to git

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Resend (resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@resend.dev   # use resend.dev sandbox for local dev

# JWT — change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# Sentry DSN for backend error tracking
SENTRY_BACKEND_DSN=https://...

# PostHog for product analytics (frontend)
VITE_PUBLIC_POSTHOG_KEY=phc_...
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog for backend analytics (can use same project key as frontend)
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com